rules_version = '2';

// ============================================================
// Firestore Security Rules — Plataforma Delben
// ============================================================
//
// Modelo de seguridad:
//   • El rol y distribuidor_id de cada usuario viven en /usuarios/{uid}.
//   • Las reglas hacen un get() a ese documento para verificar permisos.
//   • El costo Delben (costo_delben) está en snapshots de cotizaciones:
//     el aislamiento de tenant impide que un distribuidor lea cotizaciones
//     de otro. El filtro de campo por rol sigue siendo responsabilidad
//     del cliente (filtrarPorRol en el motor).
//
// Para desplegar (requiere .firebaserc con el project ID real — hoy: delben---web):
//   firebase deploy --only firestore:rules
//
// Cómo verificar el aislamiento por sede (sin desplegar a prod):
//   Emulador:  firebase emulators:start --only firestore
//   Casos mínimos (con @firebase/rules-unit-testing o manualmente en la app):
//   1. super_admin crea/edita sede  → permitido (antes daba permission-denied).
//   2. distribuidor_admin actualiza SOLO universo de una sede → permitido;
//      si intenta cambiar nombre/país/capa Delben → denegado.
//   3. Comercial con sedes_asignadas=[A]:
//        • get cotización con sede_id=A → permitido.
//        • get cotización con sede_id=B (mismo distribuidor) → DENEGADO.
//        • list cotizaciones SIN where('sede_id','in',[A]) → DENEGADO
//          (las reglas no son filtros; el cliente debe filtrar — ver getCotizaciones).
//        • list con where('sede_id','in',[A]) → permitido, solo sede A.
//   4. distribuidor_admin lista cotizaciones de todas las sedes → permitido.
//   5. Comercial de otro distribuidor → no ve ninguna (aislamiento de tenant).
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funciones helper ──────────────────────────────────────────────────────

    function autenticado() {
      return request.auth != null;
    }

    // get() se cachea por request; no hay costo extra por llamarlo varias veces.
    function perfilUsuario() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function esSuperAdmin() {
      return autenticado() && perfilUsuario().rol == 'super_admin';
    }

    function miRol() {
      return perfilUsuario().rol;
    }

    function miDistribuidorId() {
      return perfilUsuario().distribuidor_id;
    }

    function esDeDistribuidor(distribuidorId) {
      return autenticado() && miDistribuidorId() == distribuidorId;
    }

    function esAdminDeDistribuidor(distribuidorId) {
      return esDeDistribuidor(distribuidorId) && miRol() == 'distribuidor_admin';
    }

    function esRolDistribuidor() {
      return miRol() in ['distribuidor_admin', 'distribuidor_costos', 'distribuidor_comercial'];
    }

    function esFacturacionDelben() {
      return autenticado() && miRol() == 'delben_facturacion';
    }

    // ── Sedes asignadas al usuario ────────────────────────────────────────────
    // sedes_asignadas / todas_las_sedes son opcionales en /usuarios/{uid}; se leen
    // con .get(campo, default) para no fallar si el doc no los trae.
    function tieneTodasLasSedes() {
      return perfilUsuario().get('todas_las_sedes', false) == true;
    }

    function sedeAsignada(sedeId) {
      return tieneTodasLasSedes()
             || (sedeId in perfilUsuario().get('sedes_asignadas', []));
    }

    // Acceso a una cotización según su sede: el distribuidor_admin ve todas las
    // sedes de su tenant; costos/comercial solo las sedes que tienen asignadas.
    function puedeCotizacionPorSede(distribuidorId, sedeId) {
      return esDeDistribuidor(distribuidorId)
             && (miRol() == 'distribuidor_admin' || sedeAsignada(sedeId));
    }

    // ── Catálogo (lectura: todos autenticados; escritura: solo super_admin) ───

    match /tipos_estructura/{id} {
      allow read: if autenticado();
      allow write: if esSuperAdmin();
    }

    match /tipos_fachada/{id} {
      allow read: if autenticado();
      allow write: if esSuperAdmin();
    }

    match /subcategorias/{id} {
      allow read: if autenticado();
      allow write: if esSuperAdmin();
    }

    match /acabados/{id} {
      allow read: if autenticado();
      allow write: if esSuperAdmin();
    }

    match /categorias/{id} {
      allow read: if autenticado();
      allow write: if esSuperAdmin();
    }

    match /modulos/{moduloId} {
      allow read: if autenticado();
      allow write: if esSuperAdmin();

      match /precios/{precioId} {
        allow read: if autenticado();
        allow write: if esSuperAdmin();
      }
    }

    // Colección derivada para el buscador del cotizador (1 doc por nombre único).
    // No contiene costo Delben (precio_min es precio de lista). La escribe el
    // importador (super_admin); la lee cualquier usuario autenticado, igual que modulos.
    match /modulos_busqueda/{id} {
      allow read: if autenticado();
      allow write: if esSuperAdmin();
    }

    match /accesorios/{id} {
      allow read: if autenticado();
      allow write: if esSuperAdmin();
    }

    match /categorias_macro/{id} {
      allow read: if autenticado();
      allow write: if esSuperAdmin();
    }

    // ── Config global (logo Delben, etc.) ────────────────────────────────────
    // Lectura: todos autenticados (PDF necesita la URL del logo).
    // Escritura: solo super_admin.

    match /config/{docId} {
      allow read: if autenticado();
      allow write: if esSuperAdmin();
    }

    // ── Tasa USD (lectura: todos autenticados; escritura: solo super_admin) ────
    // El motor la necesita al cotizar. No contiene datos confidenciales.

    match /tasa_usd_historial/{id} {
      allow read: if autenticado();
      allow write: if esSuperAdmin();
    }

    // ── Campañas (lectura: todos autenticados; escritura: solo super_admin) ───
    // El motor necesita leerlas para calcular. No contienen datos confidenciales.

    match /campanas/{id} {
      allow read: if autenticado();
      allow write: if esSuperAdmin();
    }

    // ── Collection group: cotizaciones ────────────────────────────────────────
    // Cubre queries collectionGroup('cotizaciones') usadas en:
    //   • super_admin: vista global /admin/cotizaciones
    //   • distribuidor: getCotizaciones(distribuidorId) con where('distribuidor_id')
    // Escritura se rige por las reglas anidadas específicas.

    match /{path=**}/cotizaciones/{cotizacionId} {
      // delben_facturacion NO lee cotizaciones de distribuidores: trabaja solo con
      // sus valoraciones. El doc de cotización embebe precio de venta al cliente
      // (totales.total, resultado.precio_final_unitario), prohibido para ese rol
      // por la regla de oro #2. Separación REAL en backend (no solo UI).
      allow read: if esSuperAdmin()
                  || (esRolDistribuidor()
                      && resource.data.distribuidor_id == miDistribuidorId()
                      && (miRol() == 'distribuidor_admin'
                          || sedeAsignada(resource.data.get('sede_id', ''))));
    }

    // ── Distribuidores: aislamiento estricto por tenant ───────────────────────

    match /distribuidores/{distribuidorId} {
      // Lectura: super_admin + delben_facturacion (lista distribuidores al valorar) + el tenant.
      // delben_facturacion necesita listar distribuidores para elegir uno en /admin/valoraciones/nueva;
      // el DistribuidorDoc es identitario (nombre, ciudad, país, logo) — sin precio de venta. La regla
      // de `sedes` ya incluía a facturación; esto completa el padre.
      // Escritura: crear/borrar solo super_admin. Actualizar: super_admin (todo) o
      // distribuidor_admin (p. ej. su logo), PERO la `sigla` y `mostrar_en_web`
      // quedan bloqueadas para el admin (solo el super_admin las define: la sigla va
      // en contratos vía el consecutivo; la visibilidad pública es decisión de Delben).
      allow read: if esSuperAdmin() || esFacturacionDelben() || esDeDistribuidor(distribuidorId);
      allow create, delete: if esSuperAdmin();
      allow update: if esSuperAdmin()
                    || (esAdminDeDistribuidor(distribuidorId)
                        && request.resource.data.get('sigla', '') == resource.data.get('sigla', '')
                        && request.resource.data.get('mostrar_en_web', false) == resource.data.get('mostrar_en_web', false));

      // ── Sedes: las condiciones de cálculo viven aquí ───────────────────────
      // Lectura: super_admin, delben_facturacion (elige sede al valorar) y el tenant.
      // País + accesos + capa Delben: solo super_admin (create/delete y todo update).
      // El distribuidor_admin puede actualizar SOLO el universo: se acota fijando
      // (== resource.data) todos los demás campos, de modo que únicamente `universo`
      // puede cambiar. Es robusto (no depende de inferir qué tocó el cliente).
      match /sedes/{sedeId} {
        allow read: if esSuperAdmin() || esFacturacionDelben() || esDeDistribuidor(distribuidorId);
        allow create, delete: if esSuperAdmin();
        allow update: if esSuperAdmin()
                      || (esAdminDeDistribuidor(distribuidorId)
                          && request.resource.data.nombre == resource.data.nombre
                          && request.resource.data.pais == resource.data.pais
                          && request.resource.data.ciudad == resource.data.ciudad
                          && request.resource.data.acceso_tradicional == resource.data.acceso_tradicional
                          && request.resource.data.acceso_desarmado == resource.data.acceso_desarmado
                          && request.resource.data.descuento_muebles_pct == resource.data.descuento_muebles_pct
                          && request.resource.data.descuento_herrajes_pct == resource.data.descuento_herrajes_pct
                          && request.resource.data.servicios == resource.data.servicios
                          && request.resource.data.activo == resource.data.activo
                          && request.resource.data.created_at == resource.data.created_at
                          && request.resource.data.get('sigla', '') == resource.data.get('sigla', '')
                          && request.resource.data.get('mostrar_en_web', false) == resource.data.get('mostrar_en_web', false));

        // Historial de condiciones por sede: escritura solo super_admin.
        match /historial_condiciones/{histId} {
          allow read: if esSuperAdmin() || esFacturacionDelben() || esDeDistribuidor(distribuidorId);
          allow write: if esSuperAdmin();
        }

        // Contador del consecutivo de cotización (por sede + año). Lo incrementa
        // quien puede crear cotizaciones en la sede. El constraint +1 blinda contra
        // reinicios o saltos (evita duplicados/huecos aun ante un cliente malicioso).
        match /contadores/{anio} {
          allow read: if esSuperAdmin() || puedeCotizacionPorSede(distribuidorId, sedeId);
          allow create: if (esSuperAdmin() || puedeCotizacionPorSede(distribuidorId, sedeId))
                        && request.resource.data.ultimo == 1;
          allow update: if (esSuperAdmin() || puedeCotizacionPorSede(distribuidorId, sedeId))
                        && request.resource.data.ultimo == resource.data.ultimo + 1;
        }
      }

      // Cotizaciones (path legacy): aislamiento por tenant + por sede.
      // create usa request.resource (aún no existe el doc); el resto usa resource.
      match /cotizaciones/{cotizacionId} {
        // delben_facturacion NO lee cotizaciones de distribuidores (ver regla collectionGroup arriba).
        allow read: if esSuperAdmin()
                    || puedeCotizacionPorSede(distribuidorId, resource.data.get('sede_id', ''));
        allow create: if esSuperAdmin()
                      || puedeCotizacionPorSede(distribuidorId, request.resource.data.get('sede_id', ''));
        allow update, delete: if esSuperAdmin()
                      || puedeCotizacionPorSede(distribuidorId, resource.data.get('sede_id', ''));
      }

      // Proyectos: aislamiento por tenant (el proyecto no tiene sede; la sede vive
      // en cada cotización anidada).
      match /proyectos/{proyectoId} {
        allow read, write: if esSuperAdmin() || esDeDistribuidor(distribuidorId);

        // Cotizaciones anidadas dentro de proyectos: aislamiento por sede.
        match /cotizaciones/{cotizacionId} {
          // delben_facturacion NO lee cotizaciones de distribuidores (ver regla collectionGroup arriba).
          allow read: if esSuperAdmin()
                      || puedeCotizacionPorSede(distribuidorId, resource.data.get('sede_id', ''));
          allow create: if esSuperAdmin()
                        || puedeCotizacionPorSede(distribuidorId, request.resource.data.get('sede_id', ''));
          allow update, delete: if esSuperAdmin()
                        || puedeCotizacionPorSede(distribuidorId, resource.data.get('sede_id', ''));
        }
      }
    }

    // ── Valoraciones internas (solo Delben) ──────────────────────────────────
    // No visibles para distribuidores. delben_facturacion tiene acceso completo.

    match /valoraciones/{valoracionId} {
      allow read, write: if esSuperAdmin() || esFacturacionDelben();
    }

    // ── Usuarios ──────────────────────────────────────────────────────────────

    match /usuarios/{uid} {
      // Lectura:
      //   • super_admin: todos los usuarios
      //   • El propio usuario: su propio documento
      //   • distribuidor_admin: los usuarios de su mismo tenant
      allow read: if esSuperAdmin()
                  || request.auth.uid == uid
                  || (autenticado()
                      && miRol() == 'distribuidor_admin'
                      && resource.data.distribuidor_id == miDistribuidorId());

      // Creación:
      //   • super_admin: cualquier usuario y rol
      //   • distribuidor_admin: solo costos/comercial de su propio tenant
      allow create: if esSuperAdmin()
                    || (autenticado()
                        && miRol() == 'distribuidor_admin'
                        && request.resource.data.distribuidor_id == miDistribuidorId()
                        && request.resource.data.rol in [
                             'distribuidor_costos',
                             'distribuidor_comercial'
                           ]);

      // Actualización:
      //   • super_admin: sin restricciones
      //   • Usuario propio: no puede cambiar rol ni distribuidor_id
      //   • distribuidor_admin: puede actualizar usuarios de su tenant
      //     mientras no cambie el distribuidor_id ni eleve el rol a admin
      allow update: if esSuperAdmin()
                    || (request.auth.uid == uid
                        && request.resource.data.rol == resource.data.rol
                        && request.resource.data.distribuidor_id == resource.data.distribuidor_id)
                    || (autenticado()
                        && miRol() == 'distribuidor_admin'
                        && resource.data.distribuidor_id == miDistribuidorId()
                        && request.resource.data.distribuidor_id == miDistribuidorId()
                        && request.resource.data.rol in [
                             'distribuidor_costos',
                             'distribuidor_comercial'
                           ]);

      // Eliminación: solo super_admin
      allow delete: if esSuperAdmin();
    }
  }
}
