# ============================================================
# VARIABLES DE ENTORNO — Plataforma Delben
# Copia este archivo como .env.local y rellena los valores.
# NUNCA subas .env.local al repositorio.
# ============================================================

# Firebase (cliente — se exponen al navegador)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Nota: la app NO usa Firebase Admin SDK (el catálogo lee Firestore client-side,
# protegido por Security Rules). El único uso de firebase-admin es el script de
# mantenimiento tests/catalogo/backfill-precio-min.mjs, que se autentica con ADC
# (`gcloud auth application-default login`), no con variables de entorno.
